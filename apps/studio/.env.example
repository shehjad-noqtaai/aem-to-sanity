# Sanity Studio auto-loads this file when you run `sanity dev` or `sanity build`.
# The SANITY_STUDIO_ prefix is the officially supported way to expose values to
# the browser bundle. The unprefixed names are also accepted as fallbacks so
# you can share a single .env with the content-migration CLI.

SANITY_STUDIO_PROJECT_ID=your-project-id
SANITY_STUDIO_DATASET=production

# Optional — required only for `sanity deploy` (studio hosting).
# Find in the Studio settings page, or let `sanity deploy` create one on first run.
SANITY_STUDIO_APP_ID=
