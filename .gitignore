# Dependencies
node_modules/

# Build output & run artifacts
output
*.tsbuildinfo
dist/
.turbo/
.sanity/

# Local environment (never commit real credentials)
.env
.env.local
.env.*.local

# Project-specific input (contains customer component paths + content roots)
# Operator-authored lists stay untracked; the example's canonical lists are checked in.
aem-component-paths
aem-content-roots
!examples/davids-bridal/aem-component-paths
!examples/davids-bridal/aem-content-roots

# Example `output/` layout:
#   output/schemas/   — generated Sanity schemas; committed as a fixture so
#                       apps/studio builds + validates on bare clone.
#                       Deterministic output, so git diff shows only real
#                       changes.
#   output/cache/     — every ephemeral artifact produced by the pipeline:
#                       raw AEM trees, clean transformed docs, asset cache,
#                       captured fixtures, reports, content-type-registry.
#                       Regenerated from live AEM each run; never tracked.
!examples/davids-bridal/output/
!examples/davids-bridal/output/schemas/
!examples/davids-bridal/output/schemas/*.ts
# Cache folder stays ignored even under the output/ unignore above.
examples/davids-bridal/output/cache/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor / OS
.DS_Store
.vscode/
.idea/
*.swp
*.code-workspace
