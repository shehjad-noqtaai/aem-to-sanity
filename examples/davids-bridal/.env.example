# ---------------------------------------------------------------------------
# AEM source (required for schema + content migration)
# ---------------------------------------------------------------------------

# Which environment to pull from: "author" or "publish"
AEM_ENV=author

# Author environment (used when AEM_ENV=author)
AEM_AUTHOR_URL=https://author-aem-dev.example.com
AEM_AUTHOR_USERNAME=your-username
AEM_AUTHOR_PASSWORD=your-password

# Publish environment (used when AEM_ENV=publish)
AEM_PUBLISH_URL=https://publish-aem-dev.example.com
AEM_PUBLISH_USERNAME=your-username
AEM_PUBLISH_PASSWORD=your-password

# Optional: bearer token instead of basic auth (applies to whichever env is active)
# AEM_TOKEN=

# Optional AEM overrides (defaults shown)
# AEM_COMPONENT_PATHS_FILE=./aem-component-paths
# AEM_COMPONENT_EXCEPTIONS_FILE=./aem-component-exceptions
# AEM_CONTENT_ROOTS_FILE=./aem-content-roots
# OUTPUT_DIR=./output
# CONCURRENCY=4

# ---------------------------------------------------------------------------
# Sanity destination (required for content migration writes + studio)
# ---------------------------------------------------------------------------

SANITY_PROJECT_ID=your-project-id
SANITY_DATASET=production
# Create at https://www.sanity.io/manage → Project → API → Tokens (role: Editor or higher)
SANITY_TOKEN=your-write-token
# Optional; defaults to 2024-01-01
# SANITY_API_VERSION=2024-01-01

# ---------------------------------------------------------------------------
# aem-assets — Media Library (org-scoped assets, NOT dataset Content Lake)
# Required when MIGRATION_DRY_RUN=false.
# ---------------------------------------------------------------------------

# Org-level Media Library id (must belong to the same org as SANITY_PROJECT_ID).
# sanity.io/manage → your org → Media Library → copy the id from the URL.
SANITY_MEDIA_LIBRARY_ID=ml-xxxxxxxxxxxx

# Personal authorization token used ONLY for the Media Library → dataset link
# step. The `/assets/media-library-link` endpoint rejects project robot
# tokens with `401 Invalid non-global session` — you need a token tied to a
# user who can read/write both the Media Library and the project. Generate
# via `sanity login` + `sanity debug --secrets`, or from the Sanity user UI.
# If unset, falls back to SANITY_TOKEN.
# SANITY_ML_LINK_TOKEN=sk...
