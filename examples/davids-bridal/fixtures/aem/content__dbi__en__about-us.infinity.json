ntent/captioned-image","textIsRich":"true"},"captioned_image_975559966":{"jcr:primaryType":"nt:unstructured","jcr:createdBy":"sonali.satkar","mobileImage":"/content/dam/dbi/OCC/WGIN18977_MGREY_MOB_MAY_Q219.jpg","jcr:lastModifiedBy":"sonali.satkar","imageAlignmentControl":"left","jcr:created":"Fri Nov 15 2019 07:48:30 GMT+0000","title":"ethical sourcing","jcr:lastModified":"Fri Nov 15 2019 07:56:38 GMT+0000","desktopImage":"/content/dam/dbi/OCC/WGIN18977_MGREY_MOB_MAY_Q219.jpg","descriptionText":"<p>Our suppliers comply with the highest degree of ethical sourcing, manufacturing, and labor practices. <a href=\"#\">Read the policy.</a>.</p>\r\n","ctaLink":"#","sling:resourceType":"dbi/components/content/captioned-image","textIsRich":"true"},"captioned_image_1857873275":{"jcr:primaryType":"nt:unstructured","jcr:createdBy":"sonali.satkar","mobileImage":"/content/dam/dbi/OCC/2509UF6B_MMULTI_v1_OCC_MAY_Q219.jpg","jcr:lastModifiedBy":"sonali.satkar","imageAlignmentControl":"right","jcr:created":"Fri Nov 15 2019 07:54:21 GMT+0000","title":"tried & true","jcr:lastModified":"Fri Nov 15 2019 07:58:40 GMT+0000","desktopImage":"/content/dam/dbi/OCC/2509UF6B_MMULTI_v1_OCC_MAY_Q219.jpg","descriptionText":"<p>Simply put: We have your color. Our whole rainbow of shades—from sky blues to soft pinks to vivid greens and more—is tested in our color lab for consistency from dress to dress, in every setting.</p>\r\n","ctaLink":"#","ctaText":"Wedding colors & ideas","sling:resourceType":"dbi/components/content/captioned-image","textIsRich":"true"}}}}}}